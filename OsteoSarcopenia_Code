def generate_shap_figure():
    print(f"\n[+] Generating Figure 5: Composite SHAP Analysis...")
    fig = plt.figure(figsize=(20, 18))
    panels = ['A', 'B', 'C', 'D']
    
    for i, (outcome_name, config) in enumerate(OUTCOMES.items()):
        if not os.path.exists(config['pkl']): continue
        with open(config['pkl'], 'rb') as f: data = pickle.load(f)
        model_name = config['shap_model']
        if model_name not in data['models_dict']: continue
            
        pipe = data['models_dict'][model_name][0]
        preprocessor, selector, clf = pipe.named_steps['preprocessor'], pipe.named_steps['feature_selection'], pipe.named_steps['clf']
        
        all_features = np.concatenate([preprocessor.transformers_[0][2], preprocessor.named_transformers_['cat'].named_steps['encoder'].get_feature_names_out(preprocessor.transformers_[1][2])])
        clean_features = [f.replace('num__', '').replace('cat__', '') for f in all_features[selector.get_support()]]
        X_test_transformed = selector.transform(preprocessor.transform(data['X_test']))
        X_test_display = pd.DataFrame(X_test_transformed, columns=clean_features)
        
        if any(tree in model_name for tree in ["XGBoost", "Random Forest", "LightGBM"]):
            shap_values = shap.TreeExplainer(clf).shap_values(X_test_transformed)
            if isinstance(shap_values, list): shap_values = shap_values[1]
            elif len(np.shape(shap_values)) == 3: shap_values = shap_values[:, :, 1]
        elif "Logistic" in model_name:
            shap_values = shap.LinearExplainer(clf, X_test_transformed).shap_values(X_test_transformed)
        else:
            shap_values = shap.KernelExplainer(lambda x: clf.predict_proba(x)[:, 1], shap.kmeans(X_test_transformed, 10)).shap_values(X_test_transformed)
            if isinstance(shap_values, list): shap_values = shap_values[1]

        ax = fig.add_subplot(2, 2, i+1); plt.sca(ax)
        shap.summary_plot(shap_values, X_test_display, show=False, plot_size=None)
        ax.set_title(f"{outcome_name} ({model_name})", fontsize=16, fontweight='bold', pad=20)
        ax.text(-0.2, 1.05, panels[i], transform=ax.transAxes, fontsize=24, fontweight='bold', va='top', ha='right')

    plt.suptitle("Figure 5: Biological Interpretability and Feature Importance (SHAP)", y=1.02, fontsize=22, fontweight='bold')
    plt.tight_layout()
    plt.savefig(os.path.join(FIG_DIR, "Figure_5_SHAP_Composite.png"), dpi=300, bbox_inches='tight')
    plt.close()
    print("[+] Figure 5 saved successfully.")

