def add_panel_label(ax, label):
    ax.text(-0.1, 1.05, label, transform=ax.transAxes, fontsize=20, fontweight='bold', va='top', ha='right')

def get_style(name):
    if "Combined" in name: return 3.0, '-'
    elif "Baseline" in name: return 2.0, ':'
    else: return 2.5, '--'

def generate_outcome_figure(outcome_name, config):
    print(f"[+] Generating Figure {config['fig_num']} for {outcome_name}...")
    if not os.path.exists(config['pkl']):
        print(f"    [!] Error: {config['pkl']} not found.")
        return
        
    with open(config['pkl'], 'rb') as f: data = pickle.load(f)
    y_test, probs_dict = data['y_test'], {m: data['probs_dict'][m] for m in config['models'] if m in data['probs_dict']}
    fig, axes = plt.subplots(2, 2, figsize=(16, 14))
    colors = sns.color_palette("Set1", len(probs_dict))
    
    # A: ROC
    ax = axes[0, 0]
    add_panel_label(ax, 'A')
    for (name, y_prob), color in zip(probs_dict.items(), colors):
        fpr, tpr, _ = roc_curve(y_test, y_prob)
        lw, ls = get_style(name)
        ax.plot(fpr, tpr, lw=lw, ls=ls, color=color, label=f"{name} (AUC = {auc(fpr, tpr):.3f})")
    ax.plot([0, 1], [0, 1], 'k--', lw=1.5)
    ax.set_xlabel('False Positive Rate'); ax.set_ylabel('True Positive Rate')
    ax.set_title('Receiver Operating Characteristic (ROC)')
    ax.legend(loc='lower right')

    # B: PRC
    ax = axes[0, 1]
    add_panel_label(ax, 'B')
    for (name, y_prob), color in zip(probs_dict.items(), colors):
        prec, rec, _ = precision_recall_curve(y_test, y_prob)
        lw, ls = get_style(name)
        ax.plot(rec, prec, lw=lw, ls=ls, color=color, label=name)
    ax.set_xlabel('Recall (Sensitivity)'); ax.set_ylabel('Precision (PPV)')
    ax.set_title('Precision-Recall Curve (PRC)')
    ax.legend(loc='upper right')

    # C: Calibration
    ax = axes[1, 0]
    add_panel_label(ax, 'C')
    ax.plot([0, 1], [0, 1], "k:", label="Perfectly Calibrated")
    ax_hist = inset_axes(ax, width="40%", height="30%", loc="lower right", borderpad=2)
    for (name, y_prob), color in zip(probs_dict.items(), colors):
        prob_t, prob_p = calibration_curve(y_test, y_prob, n_bins=10)
        lw, ls = get_style(name)
        ax.plot(prob_p, prob_t, ls=ls, lw=lw, marker="s", color=color, label=f"{name} (Brier = {brier_score_loss(y_test, y_prob):.3f})")
        ax_hist.hist(y_prob, range=(0, 1), bins=10, histtype="step", lw=1.5, color=color)
    ax.set_xlabel('Predicted Probability'); ax.set_ylabel('Actual Fraction of Positives')
    ax.set_title('Calibration Curve')
    ax.legend(loc='upper left')
    ax_hist.set_yticks([]); ax_hist.set_xlabel('Prob', fontsize=8); ax_hist.tick_params(axis='x', labelsize=8)

    # D: DCA
    ax = axes[1, 1]
    add_panel_label(ax, 'D')
    thresholds = np.linspace(0.01, 0.99, 100)
    prevalence = np.mean(y_test)
    ax.plot(thresholds, [prevalence - (1 - prevalence) * (t / (1 - t)) for t in thresholds], 'k--', label='Treat All')
    ax.plot(thresholds, np.zeros_like(thresholds), 'k-', label='Treat None')
    for (name, y_prob), color in zip(probs_dict.items(), colors):
        nb_list = [(np.sum((y_prob >= t) & (y_test == 1)) / len(y_test)) - (np.sum((y_prob >= t) & (y_test == 0)) / len(y_test)) * (t / (1 - t)) for t in thresholds]
        lw, ls = get_style(name)
        ax.plot(thresholds, nb_list, lw=lw, ls=ls, color=color, label=name)
    ax.set_ylim([-0.05, max(prevalence + 0.05, 0.25)]); ax.set_xlim([0, 0.85])
    ax.set_xlabel('Threshold Probability'); ax.set_ylabel('Net Benefit')
    ax.set_title('Decision Curve Analysis (DCA)')
    ax.legend(loc='upper right')

    plt.suptitle(f"Figure {config['fig_num']}: Predictive Performance for {outcome_name}", y=1.02, fontweight='bold')
    plt.tight_layout()
    plt.savefig(os.path.join(FIG_DIR, f"Figure_{config['fig_num']}_{outcome_name.replace(' ', '_')}_Summary.png"), dpi=300, bbox_inches='tight')
    plt.close()

