def _plot_cm_grid(y_test, probs_dict, models_dict, model_names, outcome_name, sub_label, config):
    """Helper function to plot a grid of confusion matrices."""
    if not model_names: return
    
    cols = 2
    rows = (len(model_names) + cols - 1) // cols
    fig, axes = plt.subplots(rows, cols, figsize=(cols*6, rows*5))
    
    # Handle single model cases gracefully
    if len(model_names) == 1: axes = [axes]
    else: axes = axes.flatten()
    
    # Robustly find the corresponding metrics CSV for threshold fallback
    pkl_dir = os.path.dirname(config['pkl'])
    csv_files = glob.glob(os.path.join(pkl_dir, "*metrics.csv"))
    df_metrics = pd.read_csv(csv_files[0]) if csv_files else None

    for i, name in enumerate(model_names):
        y_prob = probs_dict[name]
        
        # Fetch the exact optimized threshold
        thresh = 0.5
        if name in models_dict:
            thresh = models_dict[name][1]
        elif df_metrics is not None:
            match = df_metrics[df_metrics['Model'] == name]
            if not match.empty:
                thresh = match['Threshold'].values[0]
                
        y_pred = (y_prob >= thresh).astype(int)
        cm = confusion_matrix(y_test, y_pred)
        
        ax = axes[i]
        sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=ax, cbar=False,
                    xticklabels=['Normal', outcome_name], yticklabels=['Normal', outcome_name],
                    annot_kws={"size": 16, "fontweight": "bold"})
        
        title_text = f"{name}\n(Threshold: {thresh:.2f})"
        ax.set_title(title_text, fontsize=14, fontweight='bold', pad=15)
        ax.set_ylabel('Actual Label', fontsize=12, fontweight='bold')
        ax.set_xlabel('Predicted Label', fontsize=12, fontweight='bold')
        
    for j in range(len(model_names), len(axes)): axes[j].set_visible(False)
    
    title_suffix = f" - {sub_label}" if sub_label else ""
    plt.suptitle(f"Confusion Matrices: {outcome_name}{title_suffix}", y=1.02, fontsize=18, fontweight='bold')
    plt.tight_layout()
    
    file_suffix = f"_{sub_label}" if sub_label else ""
    save_path = os.path.join(FIG_DIR, f"Figure_S{config['fig_num']}_{outcome_name.replace(' ', '_')}{file_suffix}_CM.png")
    plt.savefig(save_path, dpi=300, bbox_inches='tight')
    plt.close()
    print(f"    [+] Saved {os.path.basename(save_path)}")

def generate_outcome_cm_figures():
    print(f"\n[+] Generating Individual Confusion Matrix Figures for each outcome...")
    
    for outcome_name, config in OUTCOMES.items():
        pkl_path = config['pkl']
        if not os.path.exists(pkl_path): continue
        
        with open(pkl_path, 'rb') as f: data = pickle.load(f)
        y_test = data['y_test']
        probs_dict = data['probs_dict']
        models_dict = data['models_dict']
        
        models_to_plot = [m for m in config['models'] if m in probs_dict]
        if not models_to_plot: continue

        # For Osteosarcopenia, split Direct and Combined into two distinct figures
        if outcome_name == "Osteosarcopenia":
            direct_models = [m for m in models_to_plot if "Direct" in m]
            combined_models = [m for m in models_to_plot if "Combined" in m]
            
            _plot_cm_grid(y_test, probs_dict, models_dict, direct_models, outcome_name, "Direct", config)
            _plot_cm_grid(y_test, probs_dict, models_dict, combined_models, outcome_name, "Combined", config)
        else:
            # For everything else, plot them together in one figure
            _plot_cm_grid(y_test, probs_dict, models_dict, models_to_plot, outcome_name, "", config)

