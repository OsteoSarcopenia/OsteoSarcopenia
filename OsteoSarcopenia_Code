def consolidate_metrics():
    print("\n[+] Generating Master Metrics Table...")
    all_dataframes = []
    outcomes_map = {"osteoporosis": "Osteoporosis", "sarcopenia": "Sarcopenia", "low_bone_mass": "Low Bone Mass", "osteosarcopenia": "Osteosarcopenia"}
    
    for folder_name, outcome_label in outcomes_map.items():
        search_pattern = os.path.join(BASE_DIR, folder_name, "Whole_Cohort", "*metrics.csv")
        csv_files = glob.glob(search_pattern)
        if not csv_files: continue
            
        df = pd.read_csv(csv_files[0])
        df.insert(0, 'Outcome', outcome_label)
        
        ci_cols = [col for col in df.columns if str(col).endswith('_CI')]
        for ci_col in ci_cols:
            base_name = ci_col.replace('_CI', '')
            if base_name in df.columns: df = df.drop(columns=[base_name])
            df = df.rename(columns={ci_col: base_name})
            
        if 'Threshold' in df.columns: df['Threshold'] = df['Threshold'].apply(lambda x: round(x, 2) if pd.notnull(x) else x)
        all_dataframes.append(df)

    if not all_dataframes: return
    
    master_df = pd.concat(all_dataframes, ignore_index=True)
    pref_cols = ['Outcome', 'Model', 'Threshold', 'AUC', 'Sensitivity', 'Specificity', 'PPV', 'NPV', 'Balanced_Acc', 'Accuracy', 'F1', 'F2', 'Brier', 'p_value_vs_base']
    master_df = master_df[[col for col in pref_cols if col in master_df.columns] + [col for col in master_df.columns if col not in pref_cols]].fillna("-")
    master_df.to_csv(os.path.join(FIG_DIR, "Master_Compiled_Metrics_Table.csv"), index=False)

